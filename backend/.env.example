# ─────────────────────────────────────────────
# AI CFO Backend — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# App
APP_NAME="AI CFO – Small Business Survival Agent"
APP_VERSION="1.0.0"

# Database (SQLite — relative path from project root)
DATABASE_URL=sqlite+aiosqlite:///./ai_cfo.db

# CORS — comma-separated origins for the React frontend
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

# ─── Tesseract OCR ──────────────────────────
# Windows default install path:
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux / macOS:
# TESSERACT_CMD=/usr/bin/tesseract

# ─── Whisper STT ────────────────────────────
# tiny | base | small | medium  (larger = more accurate, slower)
WHISPER_MODEL=base
