# ─── Root .gitignore ──────────────────────────────────────────────────────────
# Covers both the backend/ Python project and the future frontend/ project.

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/
ENV/

# Secrets — NEVER commit real .env
.env
*.env

# Databases (runtime)
*.db
receipts.db
*.sqlite
*.sqlite3

# Uploaded files
uploads/
backend/uploads/

# Logs and Debug Output
*.log
logs/
output.txt
output_clean.txt
crash_log.txt

# Node / frontend
node_modules/
.next/
out/
dist/

# IDE / OS
.idea/
.vscode/
*.DS_Store
Thumbs.db

# Whisper model cache
.cache/

# Binary assets / OCR Temporary Evaluation
*.jpg
*.jpeg
*.png
*.pdf

# PaddleOCR outputs
output/
inference_results/
log_output/
